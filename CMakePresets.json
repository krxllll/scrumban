{
    "version": 4,
    "configurePresets": [
        {
            "name": "conan-debug",
            "displayName": "Conan Debug",
            "description": "Debug build using the Conan-generated single-config toolchain.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/Debug/generators/conan_toolchain.cmake",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "conan-release",
            "displayName": "Conan Release",
            "description": "Release build using the Conan-generated single-config toolchain.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/Release/generators/conan_toolchain.cmake",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "conan-debug",
            "displayName": "Build Conan Debug",
            "configurePreset": "conan-debug"
        },
        {
            "name": "conan-release",
            "displayName": "Build Conan Release",
            "configurePreset": "conan-release"
        }
    ]
}
