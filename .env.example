# Local PostgreSQL connection settings.
SCRUMBAN_DB_HOST=localhost
SCRUMBAN_DB_PORT=5432
SCRUMBAN_DB_NAME=scrumban
SCRUMBAN_DB_USER=postgres
SCRUMBAN_DB_PASSWORD=change-me

# Local Drogon server settings.
SCRUMBAN_SERVER_ADDRESS=0.0.0.0
SCRUMBAN_SERVER_PORT=8080
SCRUMBAN_SERVER_THREADS=4

# Replace this in local .env files only.
SCRUMBAN_JWT_SECRET=your-jwt-secret-here
SCRUMBAN_JWT_EXPIRATION_SECONDS=86400
